      "JdbcPetVisitExtractor.java",
      "JdbcVisitRowMapper.java",
      "OneToManyResultSetExtractor.java"
    ],
    "role": "Plain Spring JdbcClient-based data access (highest complexity, main hotspot)"
  },
  "repository_jpa": {
    "description": "JPA/Hibernate implementation — active when profile=jpa (DEFAULT)",
    "path": "src/main/java/org/springframework/samples/petclinic/repository/jpa/",
    "files": [
      "JpaOwnerRepositoryImpl.java",
      "JpaPetRepositoryImpl.java",
      "JpaVetRepositoryImpl.java",
      "JpaVisitRepositoryImpl.java"
    ],
    "role": "EntityManager-based JPA data access — default runtime profile"
  },
  "repository_springdatajpa": {
    "description": "Spring Data JPA implementation — active when profile=spring-data-jpa",
    "path": "src/main/java/org/springframework/samples/petclinic/repository/springdatajpa/",
    "files": [
      "SpringDataOwnerRepository.java",
      "SpringDataPetRepository.java",
      "SpringDataVetRepository.java",
